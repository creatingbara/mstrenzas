# ============================================================
# M&S Trenzas - Variables de entorno
# Copia este archivo a .env.local (local) y configúralas como secrets en Cloudflare Workers.
# ============================================================

# --- Supabase (Project Settings -> API) ---
NEXT_PUBLIC_SUPABASE_URL=
NEXT_PUBLIC_SUPABASE_ANON_KEY=
# Clave secreta de servicio. SOLO en el servidor. Nunca la expongas en el cliente.
SUPABASE_SERVICE_ROLE_KEY=

# --- Base de datos Postgres de Supabase ---
# Project Settings -> Database -> Connection string -> "Transaction pooler" (puerto 6543).
# Imprescindible para entornos serverless. Reemplaza [PASSWORD] por la de tu proyecto.
# Ejemplo:
# SUPABASE_DB_URL=postgresql://postgres.xxxxxxxx:[PASSWORD]@aws-0-us-east-1.pooler.supabase.com:6543/postgres
SUPABASE_DB_URL=

# --- Sitio ---
NEXT_PUBLIC_SITE_URL=http://localhost:3000

# --- Notificaciones push web (VAPID) ---
# Genera estas llaves con: pnpm exec web-push generate-vapid-keys --json
VAPID_PUBLIC_KEY=
VAPID_PRIVATE_KEY=
VAPID_SUBJECT=mailto:admin@mstrenzas.com

# --- Acceso de administrador ---
# Usuario/clave del super admin para entrar a /admin/login.
# ADMIN_SESSION_SECRET firma la cookie de sesión y es OBLIGATORIO en producción.
ADMIN_USERNAME=argenis
ADMIN_EMAIL=argenis@ms-trenzas.local
ADMIN_PASSWORD=
ADMIN_SESSION_SECRET=
